# Copia este archivo a .env y ajusta los valores.

# Conexión a PostgreSQL.
# - App dentro de docker compose: host "db", puerto 5432.
# - App en local (npm run dev) contra la BD dockerizada: localhost:5434
#   (5434 evita chocar con PostgreSQL instalados en el sistema).
DATABASE_URL=postgres://tunja:tunja@localhost:5434/tunja

# Clave secreta de Payload (cámbiala por una cadena larga y aleatoria).
PAYLOAD_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# URL pública del sitio (para metadatos, Open Graph y sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Solo producción: fuerza la sincronización del esquema en el primer despliegue.
# PAYLOAD_DB_PUSH=true

# Solo producción (docker-compose.prod.yml): contraseña de la base de datos.
# DB_PASSWORD=una-contrasena-segura
